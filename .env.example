# M-Pesa Daraja API Configuration
# Copy this file to .env and fill in your actual credentials

# Get these from: https://developer.safaricom.co.ke/
REACT_APP_MPESA_CONSUMER_KEY=your_consumer_key_here
REACT_APP_MPESA_CONSUMER_SECRET=your_consumer_secret_here
REACT_APP_MPESA_SHORTCODE=your_shortcode_here
REACT_APP_MPESA_PASSKEY=your_passkey_here

# Callback URL for M-Pesa transactions
# This should point to your backend endpoint that handles M-Pesa callbacks
REACT_APP_MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# Supabase Configuration
REACT_APP_SUPABASE_URL=https://eclnjmnskzfridylrgjo.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API Configuration
REACT_APP_API_URL=https://lake-baringo-hotel-backend.netlify.app

# Environment: 'sandbox' for testing, 'production' for live payments
REACT_APP_MPESA_ENV=sandbox
